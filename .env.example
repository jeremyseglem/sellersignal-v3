# ==============================================================
# SellerSignal v3 — Environment Variables
# ==============================================================
# Copy this file to .env for local development.
# In Railway, set these in the Variables dashboard.
# Never commit .env with real values.
# ==============================================================

# --- Supabase ---
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# --- SerpAPI ---
# For investigation searches. Big Data Plan recommended.
# Get from https://serpapi.com/account
SERPAPI_KEY=your-serpapi-key-here

# --- Anthropic ---
# For copy generation from verified facts (not decision-making)
ANTHROPIC_API_KEY=your-anthropic-key-here

# --- Stripe (carried over from v1) ---
STRIPE_SECRET_KEY=sk_test_or_sk_live_here
STRIPE_WEBHOOK_SECRET=whsec_here
STRIPE_PRICE_TERRITORY=price_id_for_299_monthly_per_zip

# --- Google Maps (Stage 2) ---
GOOGLE_MAPS_API_KEY=your-google-maps-key
GOOGLE_STREET_VIEW_API_KEY=same-or-separate-google-key

# --- Server config ---
PORT=8000
ENVIRONMENT=development  # development | staging | production

# --- Budget caps ---
# Hard ceilings to prevent runaway SerpAPI spend
MAX_SEARCHES_PER_RUN=800
MAX_SEARCHES_PER_MONTH=25000

# Frontend env vars — required for `npm run build:safe` to succeed.
#
# Vite inlines anything prefixed with VITE_ into the JS bundle at
# build time. The build runs locally on whoever's machine is about
# to commit dist/ — Railway does NOT rebuild on deploy, it just
# serves the static files. So these env vars must be present in
# the shell that runs the build, not in Railway.
#
# If either is missing, `npm run build:safe` will fail loudly with
# a "Bundle is missing Supabase config" error before letting the
# broken bundle get committed. Raw `npm run build` will NOT catch
# this — always use build:safe.
#
# The anon key is intentionally public (Row Level Security in the
# database enforces actual permissions) — it's safe to ship in JS.
# Sensitive admin/service operations use the service key, which
# lives only on the backend.

VITE_SUPABASE_URL=https://eeqsbvizgpuehphiaslo.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
